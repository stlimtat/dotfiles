{{- if eq .chezmoi.os "darwin" -}}
#!/bin/zsh

brew bundle --file=/dev/stdin <<EOF
{{ range .brew.default.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .brew.default.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .brew.default.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .brew.default.mas -}}
mas {{ .keyname | quote }}, id: {{- .keyid }}
{{ end -}}
EOF

{{ end -}}
