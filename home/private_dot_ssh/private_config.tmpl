# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config
Include ~/.colima/ssh_config
Include ~/.ssh/1Password/config
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{ if eq .chezmoi.username "spteo" -}}
Host gh github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/gh-spteo.pub
  IdentitiesOnly yes
{{ end -}}
{{ if eq .chezmoi.username "st_lim" -}}
Host 192.168.25.1 gw
  Port 22
  User root
  IdentityFile ~/.ssh/omv-stlim.pub
  IdentitiesOnly yes
Host 192.168.25.254 clearwater1601b
  Port 22
  User root
  IdentityFile ~/.ssh/omv-stlim.pub
  IdentitiesOnly yes
Host 192.168.25.100 omv
  Port 22
  User {{ .chezmoi.username }}
  IdentityFile ~/.ssh/omv-stlim.pub
  IdentitiesOnly yes
Host gh gh-st github.com
