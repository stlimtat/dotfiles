        "~/.ssh"
      ],
      "denyWrite": [
        "~/.bashrc",
        "~/.profile",
        "~/.ssh",
        "~/.zshrc"
      ]
    },
    "excludedCommands": [
      "rtk gtk clone",
      "rtk gtk fetch",
      "rtk gtk pull",
      "rtk gtk push"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "promptSuggestionEnabled": true,
  "prefersReducedMotion": true,
  "autoMemoryEnabled": false,
  "terminalProgressBarEnabled": true,
  "skipAutoPermissionPrompt": true
