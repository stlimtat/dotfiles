  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.npmjs.org",
        "registry.yarnpkg.com"
      ],
      "allowUnixSockets": [
        "/var/run/docker.sock",
        "~/.orbstack/run/docker.sock",
        "~/.ssh/agent.sock",
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ],
      "allowLocalBinding": false
    },
    "filesystem": {
      "allowRead": [
        "~/.ssh/known_hosts",
        "~/.ssh/config"
      ],
      "allowWrite": [
        "~/.bun/install",
        "~/.kube",
        "~/.local/share/pnpm",
        "~/.npm",
        "/tmp",
        "//tmp/build",
        "~/.yarn"
