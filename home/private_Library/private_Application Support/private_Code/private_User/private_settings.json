{
  "[go]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    }
  },
  "application.shellEnvironmentResolutionTimeout": 60,
  "claudeCode.initialPermissionMode": "bypassPermissions",
  "claudeCode.preferredLocation": "panel",
  "coverage-gutters.coverageFileNames": [
    "lcov.info",
    "cov.xml",
    "coverage.xml",
    "cobertura.xml",
    "jacoco.xml",
    "coverage.cobertura.xml"
  ],
  "coverage-gutters.showLineCoverage": true,
  "debug.console.fontSize": 14,
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "JetBrainsMonoNL Nerd Font, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "normal",
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "editor.lineHeight": 20,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": true,
  "editor.tabSize": 2,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "extensions.ignoreRecommendations": true,
  "github.gitProtocol": "ssh",
  "go.addTags": {
    "options": "json=omitempty,bson=omitempty,koanf=omitempty",
    "tags": "json,bson,koanf"
  },
  "go.alternateTools": {
    "customFormatter": "golangci-lint"
  },
  "go.coverShowCounts": true,
  "go.diagnostic.vulncheck": "Imports",
  "go.formatFlags": [
    "fmt",
    "--stdin"
  ],
  "go.formatTool": "gofumpt",
  "go.lintFlags": [
    "--path-mode=abs",
    "--fast-only"
  ],
  "go.lintTool": "golangci-lint",
  "go.testEnvFile": "${workspaceFolder}/.env",
  "go.testEnvVars": {
    "HTTP_PROXY": "http://127.0.0.1:8080",
    "HTTPS_PROXY": "http://127.0.0.1:8080"
  },
  "go.testExplorer.packageDisplayMode": "nested",
  "gopls": {
    "ui.semanticTokens": true
  },
  "jupyter.askForKernelRestart": false,
  "koverage.coverageFileNames": [
    "lcov.info",
    "cov.xml",
    "clover.xml",
    "coverage.xml",
    "jacoco.xml"
  ],
  "notebook.defaultFormatter": "anysphere.cursorpyright",
  "notebook.diff.overviewRuler": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.insertToolbarLocation": "notebookToolbar",
  "notebook.lineNumbers": "on",
  "notebook.output.wordWrap": true,
  "pgsql.serverGroups": [
    {
      "name": "Servers",
      "id": "B99F497B-DB25-4AC4-A207-3C4A70D167DE",
      "isDefault": true
    },
    {
      "id": "0994479E-3B92-4822-94DA-1291A5F692E9",
      "name": "Azure",
      "description": ""
    }
  ],
  "python.languageServer": "Default",
  "redhat.telemetry.enabled": true,
  "scm.inputFontSize": 14,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontSize": 14,
  "#terminal.integrated.profiles.osx#": "zsh",
  "testing.followRunningTest": true,
  "window.commandCenter": true,
  "workbench.colorTheme": "Gruvbox Dark (Medium)",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false
}
